# ===== Server =====
PORT=5000
NODE_ENV=development
# CLIENT_URL=http://localhost:4200
CLIENT_URL=http://localhost:50967
# ===== Database =====
DB_PATH=./data/hotel_billing.db
DB_BACKUP_DIR=./backups

# ===== JWT =====
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=change_this_refresh_secret_too
JWT_REFRESH_EXPIRES_IN=7d

# ===== Default Admin (used only on first seed) =====
DEFAULT_ADMIN_EMAIL=admin@hotel.com
DEFAULT_ADMIN_PASSWORD=Admin@123
DEFAULT_OWNER_EMAIL=owner@hotel.com
DEFAULT_OWNER_PASSWORD=Owner@123

# ===== Email (NodeMailer / SMTP) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="Hotel Billing System <your_email@gmail.com>"
EMAIL_ENABLED=false
OWNER_NOTIFICATION_EMAIL=owner@hotel.com

# ===== WhatsApp (choose ONE provider) =====
WHATSAPP_PROVIDER=none
# Options: none | twilio | meta

# --- Twilio ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
OWNER_WHATSAPP_NUMBER=whatsapp:+91XXXXXXXXXX

# --- Meta WhatsApp Cloud API ---
META_WA_PHONE_NUMBER_ID=
META_WA_ACCESS_TOKEN=
META_WA_RECIPIENT_NUMBER=

# ===== License System =====
LICENSE_TRIAL_DAYS=30
LICENSE_TRIAL_BILL_LIMIT=100
LICENSE_SIGNING_SECRET=change_this_license_signing_secret

# ===== Logging =====
LOG_LEVEL=info
